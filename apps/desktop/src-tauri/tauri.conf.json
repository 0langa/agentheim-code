{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Agentheim Code",
  "version": "1.0.0",
  "identifier": "dev.agentheim.code",
  "build": {
    "beforeDevCommand": "npm --prefix ../web run dev",
    "beforeBuildCommand": "npm --prefix ../web run build",
    "devUrl": "http://127.0.0.1:5173",
    "frontendDist": "../../../src/agentheim_code/web"
  },
  "app": {
    "windows": [
      {
        "title": "Agentheim Code",
        "width": 1320,
        "height": 860,
        "minWidth": 960,
        "minHeight": 680
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src 'self' http://127.0.0.1:*; img-src 'self' data:; font-src 'self' data:;"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
